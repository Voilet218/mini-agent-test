# Minimal Agent 配置
# 复制此文件为 .env 或直接设置环境变量

# 【必需】API 密钥
LLM_API_KEY=sk

# 【可选】API 地址（默认 OpenAI）
# 使用 DeepSeek:
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 使用 OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 使用 月之暗面:
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k
